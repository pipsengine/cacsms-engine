POSTGRES_DB=db_cacsms-engine
POSTGRES_USER=cacsms
POSTGRES_PASSWORD=Adm1n.c0m
DATABASE_URL=postgres://cacsms:Adm1n.c0m@localhost:5432/db_cacsms-engine
# Docker Compose overrides DATABASE_URL to postgres://...@postgres:5432/... inside containers.
# If Docker cannot pull node:20-alpine (DNS/registry issues), use a local Node image:
# NODE_RUNTIME_IMAGE=frappe/erpnext:v16.21.1
# DOCKER_PULL_POLICY=never
# Superuser URL used only by `npm run db:setup` to create role/database locally.
# POSTGRES_ADMIN_URL=postgres://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/postgres
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672
JWT_SECRET=cacsms-dev-jwt-secret-min-32-chars-long
EXECUTION_TOKEN_SECRET=cacsms-dev-exec-token-secret-32c
API_PORT=8080
WEB_PORT=4173
# Background MT5 sync/validation interval in milliseconds (0 disables).
CACSMS_AUTO_SYNC_MS=30000
COT_SYNC_ENABLED=true
COT_SYNC_DAY=SATURDAY
COT_SYNC_TIME=00:00
COT_REPORT_TYPE=FUTURES_ONLY
COT_SOURCE_URL=https://www.cftc.gov/MarketReports/CommitmentsofTraders/HistoricalCompressed/index.htm
MARKET_DATA_LIVE_URL=
NEWS_SENTIMENT_LIVE_URL=
ECONOMIC_CALENDAR_LIVE_URL=
# Licensed Trading Economics credential used for actual-release polling.
# Format accepted by their API is typically client_key:client_secret.
TRADING_ECONOMICS_API_KEY=
# Schedule sync and focused actual-release polling intervals in milliseconds.
ECONOMIC_CALENDAR_SYNC_MS=60000
ECONOMIC_CALENDAR_RELEASE_POLL_MS=15000
SOCIAL_SENTIMENT_LIVE_URL=
# X / Twitter API v2 bearer token for recent-search ingestion.
X_BEARER_TOKEN=
# Example: ("XAUUSD" OR "Gold" OR "BTCUSD" OR "NAS100") lang:en -is:retweet
X_SEARCH_QUERY=
# YouTube Data API key for comment ingestion.
YOUTUBE_API_KEY=
# Comma-separated channel IDs to search, optional when YOUTUBE_SEARCH_QUERY is set.
YOUTUBE_CHANNEL_IDS=
# Example: XAUUSD OR Gold OR BTCUSD OR NAS100
YOUTUBE_SEARCH_QUERY=
# Reddit read-only app credentials for subreddit/search ingestion.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=cacsms-engine-social-sentiment/1.0
REDDIT_SUBREDDITS=Forex,Daytrading,StockMarket,CryptoCurrency
REDDIT_SEARCH_QUERY=
# StockTwits symbol streams. Use cashtags/symbols without mock fallbacks.
STOCKTWITS_ACCESS_TOKEN=
STOCKTWITS_SYMBOLS=XAUUSD,BTCUSD,EURUSD,NASDAQ
# Telegram bot must be added to the monitored channels.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNELS=
# Discord bot needs View Channel and Read Message History permissions.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=
DISCORD_GUILD_IDS=
# Comma-separated instruments/keywords monitored by social sentiment scoring.
SOCIAL_SENTIMENT_KEYWORDS=XAUUSD,XAU/USD,Gold,BTCUSD,BTC/USD,NAS100,EURUSD,EUR/USD,USDJPY,USD/JPY
HISTORICAL_DATA_LIVE_URL=
BROKER_DATA_LIVE_URL=
ACCOUNT_PORTFOLIO_LIVE_URL=
PROP_FIRM_RULES_LIVE_URL=
