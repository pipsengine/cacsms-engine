{
  "name": "cacsms-engine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "xcopy .next\\static .next\\standalone\\.next\\static\\ /E /I /Y >NUL && if exist public xcopy public .next\\standalone\\public\\ /E /I /Y >NUL",
    "start": "next start",
    "start:iis": "node .next/standalone/server.js",
    "serve:windows": "set PORT=3000&& set HOSTNAME=127.0.0.1&& node .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "typescript": "^5.7.2"
  }
}
